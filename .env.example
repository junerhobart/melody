DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Optional — set to 0 for faster local dev streaming (innertube). Default is yt-dlp.
USE_YOUTUBE_DL=

# Anti-slur filter: off | users | everyone  (default: off)
ANTI_SLUR_MODE=

# Comma-separated Discord user IDs when ANTI_SLUR_MODE=users
ANTI_SLUR_USER_IDS=

# Custom message when blocked (optional)
ANTI_SLUR_MESSAGE=
