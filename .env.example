DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Optional — set to 0 for faster local dev streaming (innertube). Default is yt-dlp.
USE_YOUTUBE_DL=

# Anti-slur filter (all optional — default off)
# Mode: off | users | everyone
ANTI_SLUR_MODE=off

# When mode=users: comma-separated Discord user IDs
# ANTI_SLUR_USER_IDS=123456789012345678,987654321098765432

# Custom block message (blank = "That isn't allowed.")
# ANTI_SLUR_MESSAGE=
